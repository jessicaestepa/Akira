# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Email notifications (Resend)
RESEND_API_KEY=re_your_api_key
NOTIFICATION_EMAIL=you@yourdomain.com

# Deal ingestion (optional)
INGESTION_WEBHOOK_SECRET=generate-a-long-random-secret
CRON_SECRET=generate-another-long-random-secret
# DEAL_SCORING_DEBUG=true
# FLIPPA_DEBUG_RESPONSE=true
